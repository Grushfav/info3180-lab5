# Used when running `npm run dev`. Use the same host you use in the browser
# (localhost vs 127.0.0.1) as Flask, or session/CSRF cookies will not match.
# Port must match FLASK_RUN_PORT in .env (this project defaults to 8080).
# Remove or leave empty to use same-origin /api/... and the Vite proxy only.
VITE_API_ORIGIN=http://localhost:8080
